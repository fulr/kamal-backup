APP_NAME=chatwithwork
DATABASE_ADAPTER=postgres
DATABASE_URL=postgres://chatwithwork@chatwithwork-db:5432/chatwithwork_production
PGPASSWORD=change-me

# Mounted file-backed Active Storage path.
BACKUP_PATHS=/data/storage
KAMAL_BACKUP_STATE_DIR=/var/lib/kamal-backup
RESTIC_REPOSITORY=s3:https://s3.example.com/chatwithwork-backups
RESTIC_PASSWORD=change-me
RESTIC_INIT_IF_MISSING=true

AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_DEFAULT_REGION=us-east-1

RESTIC_KEEP_LAST=7
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6
RESTIC_KEEP_YEARLY=2
RESTIC_FORGET_AFTER_BACKUP=true

# The accessory runs kamal-backup schedule by default.
# 86400 means one scheduled backup per day.
BACKUP_SCHEDULE_SECONDS=86400
BACKUP_START_DELAY_SECONDS=0
RESTIC_CHECK_AFTER_BACKUP=false
RESTIC_CHECK_READ_DATA_SUBSET=

KAMAL_BACKUP_ALLOW_PRODUCTION_RESTORE=false
KAMAL_BACKUP_ALLOW_IN_PLACE_FILE_RESTORE=false
KAMAL_BACKUP_ALLOW_SUSPICIOUS_PATHS=false
